# --- Works with NO keys: catalog + quoting (public APIs) ---
PORT=3001
CRYPTOREFILLS_MCP_URL=https://api.cryptorefills.com/mcp/http
CRYPTOREFILLS_RATE_LIMIT_RPS=1
CRYPTOREFILLS_TIMEOUT_MS=5000
COW_API_URL=https://api.cow.fi/xdai/api/v1
RELAY_API_URL=https://api.relay.link

# Wrapped CRC token used for quoting (Gnosis). Set to the liquid group/wrapper
# token you target in v1 (e.g. a CRC20 wrapper with Balancer/CoW liquidity).
CRC_TOKEN_ADDRESS=

# Fee policy (basis points)
SERVICE_FEE_BPS=200
SLIPPAGE_BUFFER_BPS=100
QUOTE_TTL_SECONDS=90

# --- Required only for M2 execution (swap/bridge/pay). Leave empty for demo. ---
# Set TESTNET=chiado to run against Chiado (swap+payment mocked). Unset for mainnet.
TESTNET=
# Gnosis Chain RPC. WSS is REQUIRED — the deposit watcher subscribes to CRC
# Transfer events over it (eth_subscribe). Verified working: publicnode.
GNOSIS_RPC_WSS=wss://gnosis-rpc.publicnode.com
GNOSIS_RPC_HTTP=https://gnosis-rpc.publicnode.com
# Base Chain RPC — used for the final USDC payment leg to Cryptorefills.
BASE_RPC_HTTP=https://mainnet.base.org
# Chiado testnet (only used when TESTNET=chiado)
CHIADO_RPC_HTTP=https://rpc.chiado.gnosis.gateway.fm
CHIADO_RPC_WSS=wss://rpc.chiado.gnosis.gateway.fm/ws
# Gnosis Safe that receives buyer CRC deposits and holds funds in transit.
# Deploy at app.safe.global on Gnosis Chain with OPERATOR_KEY's address as signer.
ORCHESTRATOR_SAFE_ADDRESS=
# Private key (0x…) of the operator EOA that signs swap/bridge/payment txs and
# is a signer on the Safe above. Fund it with xDAI (Gnosis gas) + a little ETH
# on Base. HOT WALLET — keep minimal balance.
OPERATOR_KEY=
DATABASE_URL=

# --- Security ---
# Gift card codes are no longer stored at all (NON-CUSTODIAL CODE POLICY — codes
# are emailed by Cryptorefills directly to the buyer). This key is retained only
# to decrypt any LEGACY rows written before that change. New deployments do not
# need it. (AES-256-GCM, 32 bytes = 64 hex chars; `openssl rand -hex 32`.)
GIFT_CARD_ENCRYPTION_KEY=

# --- Gift card delivery ---
# NON-CUSTODIAL CODE POLICY: gift card codes are delivered by Cryptorefills
# DIRECTLY to the buyer's email (collected per order). The orchestrator never
# receives or stores a code. No mail-inbox credentials are required.

# --- Monitoring ---
# Secret for GET /api/admin/status  (e.g. openssl rand -hex 32)
ADMIN_KEY=
# Wallet balance alert thresholds (pipeline keeps running below these, but ops should top up)
CRC_BALANCE_WARN_WEI=50000000000000000000
USDC_BALANCE_WARN_WEI=10000000
