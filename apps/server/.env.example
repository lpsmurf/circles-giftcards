# --- Works with NO keys: catalog + quoting (public APIs) ---
PORT=3001
CRYPTOREFILLS_MCP_URL=https://api.cryptorefills.com/mcp/http
CRYPTOREFILLS_RATE_LIMIT_RPS=1
CRYPTOREFILLS_TIMEOUT_MS=5000
COW_API_URL=https://api.cow.fi/xdai/api/v1
RELAY_API_URL=https://api.relay.link

# Wrapped CRC token used for quoting (Gnosis). Set to the liquid group/wrapper
# token you target in v1 (e.g. a CRC20 wrapper with Balancer/CoW liquidity).
CRC_TOKEN_ADDRESS=

# Fee policy (basis points)
SERVICE_FEE_BPS=200
SLIPPAGE_BUFFER_BPS=100
QUOTE_TTL_SECONDS=90

# --- Required only for M2 execution (swap/bridge/pay). Leave empty for demo. ---
# Set TESTNET=chiado to run against Chiado (swap+payment mocked). Unset for mainnet.
TESTNET=
GNOSIS_RPC_WSS=
GNOSIS_RPC_HTTP=
# Chiado testnet (only used when TESTNET=chiado)
CHIADO_RPC_HTTP=https://rpc.chiado.gnosis.gateway.fm
CHIADO_RPC_WSS=wss://rpc.chiado.gnosis.gateway.fm/ws
ORCHESTRATOR_SAFE_ADDRESS=
OPERATOR_KEY=
DATABASE_URL=

# --- Security ---
# IMPORTANT — ENCRYPTION REQUIRED FOR PRODUCTION
# AES-256-GCM key used to encrypt gift card codes at rest (must be 32 bytes = 64 hex chars).
# Generate a secure key for production: `openssl rand -hex 32`.
# WARNING: If this variable is not set the application WILL STORE CODES IN PLAINTEXT.
# This plaintext fallback is provided ONLY for local development and demo environments
# and MUST NOT be used in production. Ensure `GIFT_CARD_ENCRYPTION_KEY` is set in
# production deployments before starting the service; failing to do so risks
# accidental exposure of sensitive gift card codes.
GIFT_CARD_ENCRYPTION_KEY=

# --- AgentMail (optional) ---
# Used to receive gift card codes delivered via email (brands that don't return the
# code in the Cryptorefills API response). Get a key at https://agentmail.to/
AGENTMAIL_API_KEY=
# Stable client_id so the same inbox is reused across restarts (default: circles-giftcards-v1)
AGENTMAIL_CLIENT_ID=

# --- Monitoring ---
# Secret for GET /api/admin/status  (e.g. openssl rand -hex 32)
ADMIN_KEY=
# Wallet balance alert thresholds (pipeline keeps running below these, but ops should top up)
CRC_BALANCE_WARN_WEI=50000000000000000000
USDC_BALANCE_WARN_WEI=10000000
