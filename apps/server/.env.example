# --- Works with NO keys: catalog + quoting (public APIs) ---
PORT=3001
CRYPTOREFILLS_MCP_URL=https://api.cryptorefills.com/mcp/http
CRYPTOREFILLS_RATE_LIMIT_RPS=1
CRYPTOREFILLS_TIMEOUT_MS=5000
COW_API_URL=https://api.cow.fi/xdai/api/v1
RELAY_API_URL=https://api.relay.link

# Wrapped CRC token used for quoting (Gnosis). Set to the liquid group/wrapper
# token you target in v1 (e.g. a CRC20 wrapper with Balancer/CoW liquidity).
CRC_TOKEN_ADDRESS=

# Fee policy (basis points)
SERVICE_FEE_BPS=200
SLIPPAGE_BUFFER_BPS=100
QUOTE_TTL_SECONDS=90

# --- Required only for M2 execution (swap/bridge/pay). Leave empty for demo. ---
GNOSIS_RPC_WSS=
ORCHESTRATOR_SAFE_ADDRESS=
OPERATOR_KEY=
DATABASE_URL=
